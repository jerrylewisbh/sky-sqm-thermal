# sky-sqm-thermal — server deployment config
# Copy to deploy/.env on the server and adjust values before running server-setup.sh

# === Project location on the server ===
PROJECT_DIR=/home/jerryfmedeiros/sky-sqm-thermal

# === NAS mounts (must exist before running setup) ===
# Mac equivalents:
#   /Volumes/allsky_images        → /mnt/allsky_images
#   /Volumes/astro_image_thermal  → /mnt/astro_image_thermal
NAS_ALLSKY_PATH=/mnt/allsky_images
NAS_THERMAL_PATH=/mnt/astro_image_thermal
NAS_THERMAL_UUID=ccd_25ccc900-4f15-4ac2-9d29-507e89f7c212

# === Postgres (existing on this server) ===
PG_HOST=10.0.0.227
PG_PORT=5432
PG_DB=cloud_analysis
PG_USER=allsky
PG_PASS=allsky

# === Labeling UI binding (LAN-only) ===
STREAMLIT_HOST=10.0.0.227
STREAMLIT_PORT=8501

# === Site coordinates ===
SITE_LAT=50.96372289434142
SITE_LON=-114.04558742947106

# === METAR stations (primary closer, secondary cross-check) ===
METAR_STATION_PRIMARY=CYYC
METAR_STATION_PRIMARY_LAT=51.1139
METAR_STATION_PRIMARY_LON=-114.0203
METAR_STATION_SECONDARY=CYBW
METAR_STATION_SECONDARY_LAT=51.1031
METAR_STATION_SECONDARY_LON=-114.3744

# === GOES products to fetch ===
# COD products are masked at Calgary's satellite zenith angle — skip them.
GOES_PRODUCTS="ACMC ACTPC ACHAC"

# === Logging ===
LOG_DIR=/var/log/sky-thermal
